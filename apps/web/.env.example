# ── Setup: ONE env file, and it lives at the repo root ────────────────────────
# The canonical file is <repo-root>/.env.local. apps/web/.env.local is a SYMLINK
# to it, so `next dev`, every `--env-file=apps/web/.env.local` npm script,
# vitest (apps/web/vitest.config.ts) and scripts/flyway.sh all read the same
# values instead of drifting between two copies.
#
# Fresh clone or new worktree, from the repo root:
#
#   cp apps/web/.env.example .env.local
#   ln -sf ../../.env.local apps/web/.env.local
#   $EDITOR .env.local
#
# Both .env.local paths are gitignored, so the symlink cannot be checked in —
# recreate it per clone. If apps/web/.env.local is a real file instead, nothing
# errors, but vitest and db:* keep reading the ROOT one and the two silently
# diverge.
#
# ── Database ──────────────────────────────────────────────────────────────────
# Supabase transaction pooler (port 6543) for serverless-friendly connections.
# URL-encode special chars in password (e.g. # → %23).
DATABASE_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres

# Optional: set to "disable" for local Postgres without SSL, "require" to force it.
# DATABASE_SSL=disable

# Optional: schema for db scripts (check-rls, sync-sports). Default: seazn_club.
# DB_SCHEMA=seazn_club

# ── Auth ──────────────────────────────────────────────────────────────────────
# 32-byte random hex secret used to sign session tokens.
# Generate: openssl rand -hex 32
AUTH_SECRET=replace_me_with_32_byte_hex_secret

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxx
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use sk_test_* for development, sk_live_* for production.
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
# Baked into the client bundle at build time — use pk_test_* / pk_live_*.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# Smoke tests only (scripts/smoke.ts) — never read by the app. A REAL test-mode
# Stripe Connect account id with charges enabled, i.e. one whose Express
# onboarding you finished by hand in the Stripe dashboard. Smoke otherwise
# fabricates an acct_smoke_* id: good enough for the app's "is this org
# onboarded?" gates, but Stripe answers resource_missing for any destination
# charge against it, so the sponsor Connect checkout can never return 201.
# Absent = smoke SKIPS (does not fail) the destination-charge assertion; the
# check still counts, so the totals match with or without it.
# STRIPE_CONNECT_TEST_ACCOUNT=acct_xxxx

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxx
RESEND_WEBHOOK_SECRET=whsec_xxxx
EMAIL_FROM=Seazn Club <noreply@mail.seazn.club>
EMAIL_REPLY_TO=support@seazn.club

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Override for OAuth redirects in non-standard environments.
# OAUTH_BASE_URL=https://seazn-club-stg.fly.dev

# ── Public base URL ───────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=sntrys_xxxx
# Server/edge-only DSN override (falls back to NEXT_PUBLIC_SENTRY_DSN):
# SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0

# ── PostHog analytics (optional) ──────────────────────────────────────────────
# Project API key (phc_…); absent = analytics fully disabled (no-op).
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxx
# Dashboard host for in-app links (US cloud default). EU: https://eu.posthog.com
# NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
# Server-side overrides (default to the public key / US ingest host):
# POSTHOG_KEY=phc_xxxx
# POSTHOG_HOST=https://us.i.posthog.com

# ── Future: Inngest ───────────────────────────────────────────────────────────
# INNGEST_EVENT_KEY=xxxx
# INNGEST_SIGNING_KEY=signkey-xxxx

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Cache-aside for entitlements + Redis-backed rate limiting. Fail-open: unset =
# app falls back to Postgres. RESP URL (Fly/Upstash), e.g.
# redis://default:<password>@fly-<db>.upstash.io:6379
# REDIS_URL=redis://default:xxxx@fly-xxxx.upstash.io:6379

# ── AI scheduling (optional) ──────────────────────────────────────────────────
# Powers the AI Schedule Architect; absent = feature disabled (graceful no-op).
# ANTHROPIC_API_KEY=sk-ant-xxxx
#
# The runner's DEFAULT is a fallback ladder (gemini → sonnet-direct → grok). But
# a rung whose provider has no API key is skipped, so with only ANTHROPIC_API_KEY
# set the ladder resolves to sonnet-direct — nothing changes for a no-OpenRouter
# deployment. Adding OPENROUTER_API_KEY (below) is THE production flip that
# activates the gemini/grok rungs. Data policy is enforced in code (deny +
# zero-retention + provider allowlist), not here.
# OPENROUTER_API_KEY=sk-or-v1-xxxx
# OpenRouter API base (default shown):
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── AI model selection overrides (optional) ───────────────────────────────────
# Force EXACTLY one model, no fallback (overrides the default ladder). On the
# AI_PROVIDER transport below. Also what an ops pin or the bench uses.
# SCHEDULING_AI_MODEL=claude-sonnet-5
# Transport for a single-model pin: "anthropic" (default) or "openrouter". The
# ladder ignores this (each rung pins its own provider).
# AI_PROVIDER=anthropic
# Replace the default ladder entirely (comma list; provider inferred per id —
# a "/" means an OpenRouter vendor prefix, else Anthropic direct):
# SCHEDULING_AI_LADDER=google/gemini-3.6-flash,claude-sonnet-5,x-ai/grok-4.5
# Phase B (officials) shares the same DEFAULT ladder but reads its OWN override
# env (independent of SCHEDULING_AI_LADDER). Officials is not independently
# benched against gemini/grok — pin it to sonnet here if you flip OpenRouter on
# before benching officials:  OFFICIALS_AI_LADDER=claude-sonnet-5
# OFFICIALS_AI_LADDER=google/gemini-3.6-flash,claude-sonnet-5,x-ai/grok-4.5
# Per-round output-token ceiling, same for every rung (default shown):
# SCHEDULING_AI_MAX_TOKENS=32000

# ── Payments / platform fee ───────────────────────────────────────────────────
# Application fee % taken on Stripe Connect registration payments. Default: 5.
# PLATFORM_FEE_PERCENT=5

# ── Billing (optional) ────────────────────────────────────────────────────────
# Set to "1" to re-enable the legacy Stripe Billing Portal redirect fallback
# (billing is managed in-app since v3/11).
# BILLING_PORTAL_FALLBACK=1

# ── Cron / internal endpoints (optional) ──────────────────────────────────────
# Shared secret for x-cron-secret header on /api/cron/* , /api/funnel/remind and
# /api/internal/revalidate. Mirror into GitHub Actions (gh secret set CRON_SECRET)
# and the Fly app. Generate: openssl rand -hex 32
# CRON_SECRET=replace_me

# ── ISR peer revalidation (optional, Fly multi-machine) ───────────────────────
# Set to "1" to broadcast tag revalidations to peer machines over Fly internal
# DNS. Requires CRON_SECRET; FLY_APP_NAME/FLY_PRIVATE_IP are injected by Fly.
# PEER_REVALIDATE=1

# ── CDN purge seam (optional) ─────────────────────────────────────────────────
# POSTed on tag revalidation so an edge CDN can purge; absent = no-op.
# CDN_PURGE_URL=https://cdn.example.com/purge
# CDN_PURGE_TOKEN=xxxx

# ── Security ───────────────────────────────────────────────────────────────────
# CSP is emitted as Report-Only by default (observe violations in the browser
# console). Set to "enforce" to block — only after verifying on staging, since
# enforcing nonce CSP forces dynamic rendering (no static/CDN caching).
CSP_MODE=report-only
