{
  "name": "seazn-club",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/web",
    "start": "npm run start --workspace apps/web",
    "lint": "npm run lint --workspace apps/web",
    "test": "npm run test --workspace apps/web && npm run test --workspace packages/engine",
    "test:watch": "npm run test:watch --workspace apps/web",
    "test:coverage": "npm run test:coverage --workspace apps/web",
    "test:smoke": "node --experimental-strip-types scripts/smoke.ts",
    "sim": "npm run sim --workspace packages/engine",
    "sim:replay": "npm run sim:replay --workspace packages/engine --",
    "engine:boundary": "node --experimental-strip-types scripts/engine-boundary.ts",
    "db:apply": "bash scripts/flyway.sh migrate",
    "db:info": "bash scripts/flyway.sh info",
    "db:validate": "bash scripts/flyway.sh validate",
    "db:baseline": "bash scripts/flyway.sh baseline",
    "sync:sports": "node --experimental-strip-types scripts/sync-sports.ts",
    "openapi:gen": "node --experimental-strip-types scripts/openapi-gen.ts",
    "check:rls": "node --experimental-strip-types scripts/check-rls.ts"
  }
}
